# Copy to backend/.env and fill in your OWN values.
# This template must contain ONLY placeholders — never real secrets.
# (.env is git-ignored and holds the real keys.)

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (Google AI Studio) — key starts with AIzaSy or AQ.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# App
CORS_ORIGIN=http://localhost:5173
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Paper sources (all optional; keyless works, keys raise rate limits)
S2_API_KEY=
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=samhita
UNPAYWALL_EMAIL=you@example.com

# Supabase (auth). Frontend uses VITE_SUPABASE_* vars; the backend needs the
# project URL and JWT secret to verify tokens.
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret
