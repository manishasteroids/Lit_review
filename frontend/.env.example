# Copy to frontend/.env and fill in your own values (placeholders only here).
VITE_API_BASE=http://localhost:8015

# Supabase auth (optional — leave unset to run WITHOUT login).
# The anon/publishable key is safe to expose in the browser, but keep this
# template as placeholders and put real values in frontend/.env (git-ignored).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
